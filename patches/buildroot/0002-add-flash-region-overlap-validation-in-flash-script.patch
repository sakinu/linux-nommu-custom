From e955abd6ccae6178e2c870c569db8e8f34847ff1 Mon Sep 17 00:00:00 2001
From: sakinu <sakinu080712345@gmail.com>
Date: Sat, 9 May 2026 07:39:09 +0800
Subject: [PATCH 2/3] add flash region overlap validation in flash script

---
 .../stm32f429-disco/flash.sh                  | 62 +++++++++++++++++--
 .../stm32f429-disco/linux.config              |  2 +-
 configs/stm32f429_disco_xip_defconfig         |  1 -
 3 files changed, 59 insertions(+), 6 deletions(-)

diff --git a/board/stmicroelectronics/stm32f429-disco/flash.sh b/board/stmicroelectronics/stm32f429-disco/flash.sh
index 3e2bf121..2d373c89 100755
--- a/board/stmicroelectronics/stm32f429-disco/flash.sh
+++ b/board/stmicroelectronics/stm32f429-disco/flash.sh
@@ -14,13 +14,67 @@ if ! test -d "${OUTPUT_DIR}" ; then
     exit 1
 fi
 
-${OUTPUT_DIR}/host/bin/openocd -f board/${BOARD_NAME}.cfg \
+# Memory layout (same as QEMU target in repo/Makefile)
+BOOTLOADER_ADDR=0x08000000
+DTB_ADDR=0x08004000
+XIP_ADDR=0x0800C000
+ROOTFS_ADDR=0x08180000
+FLASH_END_ADDR=0x081FFFFF
+
+BOOTLOADER="${OUTPUT_DIR}/images/stm32f429i-disco.bin"
+DTB="${OUTPUT_DIR}/images/stm32f429-disco.dtb"
+XIP="${OUTPUT_DIR}/images/xipImage"
+ROOTFS="${OUTPUT_DIR}/images/rootfs.cpio"
+
+# Check file existence
+for f in "$BOOTLOADER" "$DTB" "$XIP" "$ROOTFS" ; do
+    if [ ! -f "$f" ]; then
+        echo "ERROR: file not found: $f"
+        exit 1
+    fi
+done
+
+bootloader_size=$(stat -c%s "$BOOTLOADER")
+dtb_size=$(stat -c%s "$DTB")
+xip_size=$(stat -c%s "$XIP")
+rootfs_size=$(stat -c%s "$ROOTFS")
+
+bootloader_end=$((BOOTLOADER_ADDR + bootloader_size))
+dtb_end=$((DTB_ADDR + dtb_size))
+xip_end=$((XIP_ADDR + xip_size))
+rootfs_end=$((ROOTFS_ADDR + rootfs_size))
+
+echo "BOOTLOADER:     $(printf '0x%08X' $BOOTLOADER_ADDR) -> $(printf '0x%08X' $bootloader_end) (size $bootloader_size)"
+echo "DTB:     $(printf '0x%08X' $DTB_ADDR) -> $(printf '0x%08X' $dtb_end) (size $dtb_size)"
+echo "XIP:     $(printf '0x%08X' $XIP_ADDR) -> $(printf '0x%08X' $xip_end) (size $xip_size)"
+echo "ROOTFS:  $(printf '0x%08X' $ROOTFS_ADDR) -> $(printf '0x%08X' $rootfs_end) (size $rootfs_size)"
+
+if [ "$bootloader_end" -gt "$DTB_ADDR" ]; then
+    echo "ERROR: BOOTLOADER overlaps DTB"
+    exit 1
+fi
+if [ "$dtb_end" -gt "$XIP_ADDR" ]; then
+    echo "ERROR: DTB overlaps XIP"
+    exit 1
+fi
+if [ "$xip_end" -gt "$ROOTFS_ADDR" ]; then
+    echo "ERROR: XIP overlaps ROOTFS"
+    exit 1
+fi
+if [ "$rootfs_end" -gt "$FLASH_END_ADDR" ]; then
+    echo "ERROR: ROOTFS overlaps FLASH_END"
+    exit 1
+fi
+echo "OK: No overlap detected"
+
+"${OUTPUT_DIR}/host/bin/openocd" -f "board/${BOARD_NAME}.cfg" \
   -c "init" \
   -c "reset init" \
   -c "flash probe 0" \
   -c "flash info 0" \
-  -c "flash write_image erase ${OUTPUT_DIR}/images/stm32f429i-disco.bin 0x08000000" \
-  -c "flash write_image erase ${OUTPUT_DIR}/images/stm32f429-disco.dtb 0x08004000" \
-  -c "flash write_image erase ${OUTPUT_DIR}/images/xipImage 0x0800C000" \
+  -c "flash write_image erase ${BOOTLOADER} ${FLASH_BASE}" \
+  -c "flash write_image erase ${DTB} ${DTB_ADDR}" \
+  -c "flash write_image erase ${XIP} ${XIP_ADDR}" \
+  -c "flash write_image erase ${ROOTFS} ${ROOTFS_ADDR}" \
   -c "reset run" \
   -c "shutdown"
diff --git a/board/stmicroelectronics/stm32f429-disco/linux.config b/board/stmicroelectronics/stm32f429-disco/linux.config
index 02d9c2d1..428152f9 100644
--- a/board/stmicroelectronics/stm32f429-disco/linux.config
+++ b/board/stmicroelectronics/stm32f429-disco/linux.config
@@ -33,7 +33,7 @@ CONFIG_BUG=y
 # CONFIG_KALLSYMS is not set
 CONFIG_KCMP=y
 # CONFIG_RSEQ is not set
-CONFIG_EMBEDDED=y
+CONFIG_EXPERT=y
 # CONFIG_VM_EVENT_COUNTERS is not set
 # CONFIG_COMPAT_BRK is not set
 CONFIG_SLOB=y
diff --git a/configs/stm32f429_disco_xip_defconfig b/configs/stm32f429_disco_xip_defconfig
index d241de9a..bdb0bf3d 100644
--- a/configs/stm32f429_disco_xip_defconfig
+++ b/configs/stm32f429_disco_xip_defconfig
@@ -4,7 +4,6 @@ BR2_PACKAGE_HOST_LINUX_HEADERS_CUSTOM_7_0=y
 # BR2_UCLIBC_INSTALL_UTILS is not set
 BR2_ENABLE_LTO=y
 BR2_GLOBAL_PATCH_DIR="board/stmicroelectronics/stm32f429-disco/patches"
-# BR2_DOWNLOAD_FORCE_CHECK_HASHES is not set
 BR2_ROOTFS_POST_BUILD_SCRIPT="board/stmicroelectronics/common/stm32f4xx/stm32-post-build.sh"
 BR2_LINUX_KERNEL=y
 BR2_LINUX_KERNEL_CUSTOM_VERSION=y
-- 
