From 74f1f52f5263621a3e148c1f82245f6db484f629 Mon Sep 17 00:00:00 2001
From: sakinu <sakinu080712345@gmail.com>
Date: Sun, 10 May 2026 10:00:48 +0800
Subject: [PATCH 2/3] enable SDIO SD card support

---
 arch/arm/boot/dts/st/stm32f429-disco.dts | 19 +++++++++++++++++++
 1 file changed, 19 insertions(+)

diff --git a/arch/arm/boot/dts/st/stm32f429-disco.dts b/arch/arm/boot/dts/st/stm32f429-disco.dts
index 10401a8d5..ee3d6f583 100644
--- a/arch/arm/boot/dts/st/stm32f429-disco.dts
+++ b/arch/arm/boot/dts/st/stm32f429-disco.dts
@@ -120,6 +120,25 @@ vcc5v_otg: vcc5v-otg-regulator {
 		regulator-name = "vcc5_host1";
 		regulator-always-on;
 	};
+
+	v3v3: regulator-3v3 {
+		compatible = "regulator-fixed";
+		regulator-name = "v3v3";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		regulator-always-on;
+	};
+};
+
+&sdio {
+	pinctrl-names = "default", "opendrain";
+	pinctrl-0 = <&sdio_pins>;
+	pinctrl-1 = <&sdio_pins_od>;
+	max-frequency = <1000000>;
+	bus-width = <4>;
+	broken-cd;
+	vmmc-supply = <&v3v3>;
+	status = "okay";
 };
 
 &clk_hse {
-- 
2.54.0

